# Besu RPC URL for local (non-container) API run.
# If node-1 (8545) is stalled, try 8547, 8549, or 8551.
RPC_URL=http://localhost:8545

# Besu RPC URL used by the API container.
# From inside Docker, use host.docker.internal to reach host ports.
RPC_URL_DOCKER=http://host.docker.internal:8547

# Address printed at the end of `make devnet-deploy`.
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Pre-funded key from SimpleStorage/.env.example (local dev only).
PRIVATE_KEY=0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63

# PostgreSQL connection used by the app.
DB_URL=postgres://admin:password@localhost:5432/goledger_db?sslmode=disable

# Optional override for contract artifact path.
# Default (local): ../SimpleStorage/out/SimpleStorage.sol/SimpleStorage.json
CONTRACT_ARTIFACT_PATH=
